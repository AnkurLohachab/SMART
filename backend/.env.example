# Server Configuration
APP_NAME=SMART API
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Neo4j Configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# MinIO Configuration
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_BUCKET_NAME=model-cards

# Blockchain Configuration
WEB3_PROVIDER_URL=http://localhost:8545
CHAIN_ID=1337
# Signer keys (no keys are committed). For local Hardhat, paste the accounts
# printed by `npx hardhat node` here. See README "Local development keys".
PRIVATE_KEY=
WALLET_ADDRESS=
RELAYER_PRIVATE_KEY=
# JSON map of {"address": "private_key"} for local test signers, e.g. {"0x..":"0x.."}
HARDHAT_TEST_ACCOUNTS={}

# Contract Addresses (update after deployment)
IDENTITY_REGISTRY_ADDRESS=
MODEL_CARD_SBT_ADDRESS=
MODEL_CARD_REGISTRY_ADDRESS=
CUSTOM_ACCOUNT_FACTORY_ADDRESS=
GASLESS_RELAYER_ADDRESS=
USERNAME_REGISTRY_ADDRESS=

# Authentication
JWT_SECRET_KEY=your-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
OTP_EXPIRY_SECONDS=300

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@modelcardplatform.com

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# SSL (for production)
SSL_CERTFILE=/app/ssl/server.crt
SSL_KEYFILE=/app/ssl/server.key
